{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ozky",
  "version": "0.1.0",
  "identifier": "com.xavio.ozky",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && node src-tauri/stage-prover-bundle.mjs",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "ozky",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "prover-bundle/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
